# Copy this file to .env and fill in the values. .env is gitignored — never commit it.

# Token from @BotFather (looks like 123456789:AAE...xyz)
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat id — the bot only talks to and obeys this chat
TELEGRAM_CHAT_ID=

# Instagram username whose LOGIN SESSION is used to read stories.
# Create the session once with:  instaloader --login <this username>
# Use a secondary account, not your main one.
IG_LOGIN_USERNAME=
